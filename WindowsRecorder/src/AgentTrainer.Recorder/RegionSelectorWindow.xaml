<Window x:Class="AgentTrainer.Recorder.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select capture region" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="#66000000" Topmost="True" ShowInTaskbar="False"
        Cursor="Cross" KeyDown="OnKeyDown" MouseLeftButtonDown="OnMouseDown"
        MouseMove="OnMouseMove" MouseLeftButtonUp="OnMouseUp">
    <Grid x:Name="Root">
        <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20" Padding="16,10"
                CornerRadius="10" Background="#EA11141C" BorderBrush="#6640D9FF" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Draw the screen area to record" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Drag to select • Esc cancels" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
        <Canvas x:Name="SelectionCanvas" IsHitTestVisible="False">
            <Border x:Name="SelectionBorder" Visibility="Collapsed" BorderBrush="{StaticResource CyanBrush}" BorderThickness="2"
                    Background="#1640D9FF" CornerRadius="3">
                <TextBlock x:Name="SizeLabel" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8"
                           Padding="7,3" Background="#D911141C" FontWeight="SemiBold" />
            </Border>
        </Canvas>
    </Grid>
</Window>
